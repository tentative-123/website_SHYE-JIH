---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { content, resolveLang, t } from "../../lib/content";

export function getStaticPaths() {
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const lang = resolveLang(Astro.params.lang);
const quality = content.quality;
---
<SiteLayout
  lang={lang}
  page="quality"
  path="/quality"
  title={t(quality.metaTitle, lang)}
  description={t(quality.metaDescription, lang)}
>
  <section class="page-hero">
    <div class="container page-hero-grid">
      <div>
        <p class="eyebrow" data-cms-field="quality.eyebrow">{t(quality.eyebrow, lang)}</p>
        <h1 data-cms-field="quality.pageTitle">{t(quality.pageTitle, lang)}</h1>
        <p class="hero-text" data-cms-field="quality.pageDescription">{t(quality.pageDescription, lang)}</p>
      </div>
      <div class="image-placeholder image-wide has-image">
        <img class="media-image" data-cms-field="quality.heroImage.url" src={quality.heroImage.url} alt={t(quality.heroImage.alt, lang)} loading="lazy" />
        <small class="media-caption" data-cms-field="quality.heroImage.caption">{t(quality.heroImage.caption, lang)}</small>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container quality-grid">
      <article class="detail-card">
        <div class="image-placeholder image-card has-image">
          <img class="media-image" data-cms-field="quality.certImage.url" src={quality.certImage.url} alt={t(quality.certImage.alt, lang)} loading="lazy" />
          <small class="media-caption" data-cms-field="quality.certImage.caption">{t(quality.certImage.caption, lang)}</small>
        </div>
        <h3 data-cms-field="quality.certTitle">{t(quality.certTitle, lang)}</h3>
        <ul>
          {quality.certItems.map((item: any, index: number) => (
            <li data-cms-field={`quality.certItems.${index}`}>{t(item, lang)}</li>
          ))}
        </ul>
      </article>

      <article class="detail-card">
        <h3 data-cms-field="quality.inspectionTitle">{t(quality.inspectionTitle, lang)}</h3>
        <ul>
          {quality.inspectionItems.map((item: any, index: number) => (
            <li data-cms-field={`quality.inspectionItems.${index}`}>{t(item, lang)}</li>
          ))}
        </ul>
      </article>

      <article class="detail-card">
        <div class="image-placeholder image-card has-image">
          <img class="media-image" data-cms-field="quality.measureImage.url" src={quality.measureImage.url} alt={t(quality.measureImage.alt, lang)} loading="lazy" />
          <small class="media-caption" data-cms-field="quality.measureImage.caption">{t(quality.measureImage.caption, lang)}</small>
        </div>
        <h3 data-cms-field="quality.measureTitle">{t(quality.measureTitle, lang)}</h3>
        <ul>
          {quality.measureItems.map((item: any, index: number) => (
            <li data-cms-field={`quality.measureItems.${index}`}>{t(item, lang)}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</SiteLayout>
